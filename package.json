{
  "name": "street-world",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @street-world/web dev & pnpm --filter @street-world/api start:dev",
    "dev:web": "pnpm --filter @street-world/web dev",
    "dev:api": "pnpm --filter @street-world/api start:dev",
    "build": "pnpm --filter @street-world/web build && pnpm --filter @street-world/api build",
    "lint": "pnpm --filter @street-world/web lint && pnpm --filter @street-world/api lint"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6"
  }
}
